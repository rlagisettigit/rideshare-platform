DB_HOST=localhost
DB_PORT=3306
DB_NAME=rideshare
DB_USERNAME=rideshare
DB_PASSWORD=rideshare

REDIS_HOST=localhost
REDIS_PORT=6379

KAFKA_BROKERS=localhost:9092

JWT_SECRET=replace-with-a-long-random-256-bit-secret

MAPPLS_API_KEY=

# Email notifications (Resend - https://resend.com). Set EMAIL_NOTIFICATIONS_ENABLED=false to
# turn off email sending entirely without touching code; in-app notifications are unaffected.
EMAIL_NOTIFICATIONS_ENABLED=true
RESEND_API_KEY=
RESEND_FROM_EMAIL=Waypoint <onboarding@resend.dev>

# Optional: embeds a small route map image in ride/booking emails via Google Static Maps.
# Leave blank to send emails without a map.
GOOGLE_STATIC_MAPS_API_KEY=
