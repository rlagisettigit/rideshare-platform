# Google Maps JavaScript API key with the Places API enabled.
# Restrict this key to your site's HTTP referrers in the Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=

# OAuth 2.0 Web client ID from Google Cloud Console (Credentials > OAuth client ID > Web
# application). Used client-side only for Google Identity Services (Sign In With Google) - this
# is a public identifier, not a secret. Must match one of the backend's GOOGLE_CLIENT_IDS, and
# this origin must be added under the client's "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=
